script = ExtResource("1")
content_id = "legion_prefect"
category = "commander"
display_name = "Legion Prefect"
display_name_de = "Legionspräfekt"
short_description = "Standard support commander focused on focus fire and tower beacons."
short_description_de = "Standard-Support-Commander für Fokusfeuer und Turm-Beacons."
description = "A disciplined battlefield commander built to enhance tower placement and target focus without becoming a one-unit army. It is the clearest MVP commander for the prototype roster."
description_de = "Ein disziplinierter Schlachtfeld-Commander, der Tower-Platzierung und Zielpriorisierung stärkt, ohne selbst zur Ein-Mann-Armee zu werden. Er ist die klarste MVP-Commander-Wahl für den Prototyp."
tags = PackedStringArray("commander", "support", "ballistic", "doctrine", "mvp")
extra_stats = {"role": "support commander", "armor_rating": 3, "movement": 3.2, "dps": 58.0, "secondary_ability_name": "Bulwark Beacon", "secondary_ability_description": "Creates a 5.0 radius beacon for 8s: towers gain +15% attack speed and +10% range.", "passive_name": "Battle Doctrine", "passive_description": "Towers within 3.0 gain +8% target reaction / accuracy."}
